+/* CUDA-aware variant of parsec_dtd_taskpool_insert_task. See header for the
+ * public contract. The first call for (cpu_fpointer, nb_flows) creates the
+ * task class and attaches a CUDA chore that delegates to cuda_fpointer.
+ * Subsequent calls reuse the cached task class; mismatched cuda_fpointer is
+ * a programming error. */
+void
+parsec_dtd_taskpool_insert_task_cuda(parsec_taskpool_t           *tp,
+                                     parsec_dtd_funcptr_t        *cpu_fpointer,
+                                     parsec_dtd_cuda_funcptr_t   *cuda_fpointer,
+                                     int                          priority,
+                                     const char                  *name_of_kernel,
+                                     ...)
+{
+    va_list args;
+    va_start(args, name_of_kernel);
+
+    parsec_task_t *this_task = __parsec_dtd_taskpool_create_task(tp, cpu_fpointer, priority,
+                                                                  name_of_kernel, args);
+    va_end(args);
+
+    if( NULL == this_task ) {
+        parsec_fatal("Unknow Error! Could not create task\n");
+    }
+
+#if defined(PARSEC_HAVE_CUDA)
+    {
+        parsec_dtd_task_class_t *dtd_tc =
+            (parsec_dtd_task_class_t *)this_task->task_class;
+        if( NULL == dtd_tc->cuda_fpointer ) {
+            /* First insertion of this task class: attach the CUDA chore.
+             * Order matters: __parsec_execute (scheduling.c:152) iterates
+             * incarnations[] in order and only advances past a chore when its
+             * hook returns PARSEC_HOOK_RETURN_NEXT. The CPU hook
+             * (hook_of_dtd_task) always returns DONE, so CUDA must be tried
+             * first; hook_of_dtd_task_cuda returns NEXT when no GPU is
+             * available, falling through to the CPU chore. Mirror the JDF
+             * convention (BODY [type=CUDA] listed before default CPU BODY). */
+            __parsec_chore_t *incs =
+                (__parsec_chore_t *)dtd_tc->super.incarnations;
+            dtd_tc->cuda_fpointer = (void *)cuda_fpointer;
+            incs[1] = incs[0];                       /* CPU moves to slot 1 */
+            incs[0].type     = PARSEC_DEV_CUDA;
+            incs[0].evaluate = NULL;
+            incs[0].hook     = hook_of_dtd_task_cuda;
+            incs[0].dyld     = NULL;
+            incs[0].dyld_fn  = NULL;
+            incs[2].type     = PARSEC_DEV_NONE;
+            incs[2].evaluate = NULL;
+            incs[2].hook     = NULL;
+            incs[2].dyld     = NULL;
+            incs[2].dyld_fn  = NULL;
+
+            /* DTD taskpools are handed to parsec_context_add_taskpool with zero
+             * task classes, so parsec_cuda_taskpool_register has already cleared
+             * every CUDA device from tp->devices_index_mask. Now that this task
+             * class carries a CUDA chore, re-arm the mask and re-run the per-
+             * device register hook so parsec_gpu_get_best_device will consider
+             * the GPU at dispatch time. */
+            for( uint32_t d = 0; d < parsec_nb_devices; d++ ) {
+                parsec_device_t *dev = parsec_devices_get(d);
+                if( NULL == dev ) continue;
+                if( PARSEC_DEV_CUDA != dev->type ) continue;
+                tp->devices_index_mask |= (1u << dev->device_index);
+                if( NULL != dev->device_taskpool_register ) {
+                    (void) dev->device_taskpool_register(dev, tp);
+                }
+            }
+        } else {
+            assert( dtd_tc->cuda_fpointer == (void *)cuda_fpointer );
+        }
+    }
+#else
+    (void)cuda_fpointer;
+#endif
+
+    parsec_insert_dtd_task(this_task);
+}
