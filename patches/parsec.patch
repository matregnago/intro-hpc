+ * available (PARSEC_MCA_device_cuda_enabled=0 or no devices found) the chore
+ * returns PARSEC_HOOK_RETURN_NEXT and the CPU chore runs.
+ *
+ * When PaRSEC was compiled without CUDA support, this function ignores
+ * cuda_fpointer and behaves exactly like parsec_dtd_taskpool_insert_task.
+ */
+void
+parsec_dtd_taskpool_insert_task_cuda(parsec_taskpool_t           *tp,
