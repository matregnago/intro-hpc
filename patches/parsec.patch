+ * argument: the CUDA stream the task should submit work to (passed as void*
+ * so this header does not need to pull in <cuda_runtime.h>; callers cast to
+ * cudaStream_t). The implementation is responsible for invoking cuBLAS/cuSOLVER
+ * with that stream (e.g. cublasSetStream(handle, (cudaStream_t)stream)).
+ */
+typedef int (parsec_dtd_cuda_funcptr_t)(parsec_execution_stream_t *,
+                                        parsec_task_t *,
+                                        void *cuda_stream);
+
+/*
+ * Insert a DTD task that has both a CPU body and a CUDA body. The first call
+ * for a given cpu_fpointer creates the task class and attaches the CUDA chore;
+ * subsequent calls reuse the cached task class (so the cuda_fpointer must match
+ * the first call's value).
