# LASWP

# nb: Tile size
# n: Order of the matrix A
# lda: Leading dimension of matrix A
# k1: First element of ipiv to apply the permutation.
# k2: Last element of ipiv to apply the permutation.
# dir: Specifies the order of the permutation.

op = laswp
nb = 4, 16, 17
n = 15, 21, 35
